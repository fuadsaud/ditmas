include ~/.config/sway/colors
include ~/.config/wm/config

for_window [app_id=".*"] border pixel 0

floating_modifier $mod normal

input type:touchpad {
  tap enabled
  natural_scroll enabled
  dwt enabled
}

bindsym XF86MonBrightnessUp   exec brightnessctl set +10%
bindsym XF86MonBrightnessDown exec brightnessctl set 10%-

bindsym $mod+a exec wtype -M ctrl a -m ctrl
bindsym $mod+c exec dcopy
bindsym $mod+v exec dpaste

bindsym $mod+Shift+x exec kanshictl reload

set $wallpaper ~/.config/wallpaper

exec systemctl --user import-environment WAYLAND_DISPLAY DISPLAY
exec /usr/bin/dunst
exec gammastep
exec swayidle -w timeout 300 'swaylock -f -i $wallpaper --scaling fill' before-sleep 'swaylock -f -i $wallpaper --scaling fill'
exec kanshi
exec [ -f $wallpaper ] && swaybg -i $wallpaper -m fill
bar {
    swaybar_command waybar
}
