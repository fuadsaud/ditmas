[global]
    monitor = 0
    follow = none

    width = 500
    origin = bottom-right
    offset = 50x130

    indicate_hidden = yes
    shrink = no
    transparency = 10
    separator_height = 10
    padding = 20
    horizontal_padding = 20
    frame_width = 0
    frame_color = "#1f2433"
    separator_color = "#ffffff00"
    sort = yes
    idle_threshold = 120

    font = ProFont for Powerline 11
    line_height = 0
    markup = full
    format = "<b>%s</b>\n\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position = left
    min_icon_size = 0
    max_icon_size = 128
    icon_path = /usr/share/icons/gnome/16x16/status/:/usr/share/icons/gnome/16x16/devices/

    sticky_history = yes
    history_length = 20

    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/google-chrome-stable --new-window
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 0
    ignore_dbusclose = false
    force_xinerama = false

    mouse_left_click = do_action, close_current
    mouse_middle_click = close_all
    mouse_right_click = close_current

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "#d3cbaf"
    foreground = "#1f2433"
    timeout = 10

[urgency_normal]
    background = "#d3cbaf"
    foreground = "#1f2433"
    timeout = 30

[urgency_critical]
    background = "#cb2656"
    foreground = "#d3cbaf"
    frame_color = "#1f2433"
    timeout = 0
