#!/usr/bin/env bash

set -euo pipefail

function status_to_icon {
  echo ţéÜ

  while read -r status; do
    if [ "$status" = "Stopped" ]; then
      echo ţéÜ
    elif [ "$status" = "Paused"  ]; then
      echo ţéÜ
    else
      echo ţéŤ
    fi
  done
}

playerctl status --follow 2>/dev/null | status_to_icon
