#!/usr/bin/env bash

set -euo pipefail

exclude_host=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --exclude)
      exclude_host="$2"
      shift 2
      ;;
    *)
      echo "Usage: dmls [--exclude <host>]" >&2
      exit 1
      ;;
  esac
done

all_packages() {
  ls "${DITMAS_DIR}/stow"
}

excluded_packages() {
  if [[ "$exclude_host" == "*" ]]; then
    cat "${DITMAS_DIR}"/hosts/*.d/stow | sort -u
  else
    local host_packages="${DITMAS_DIR}/hosts/${exclude_host}.d/stow"
    if [[ ! -e "$host_packages" ]]; then
      echo "dmls: no stow list for host '${exclude_host}'" >&2
      exit 1
    fi
    cat "$host_packages"
  fi
}

if [[ -n "$exclude_host" ]]; then
  all_packages | grep -vxF -f <(excluded_packages)
else
  all_packages
fi
