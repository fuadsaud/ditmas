[user]
  name = Fuad Saud
  email = fuadfsaud@gmail.com
[include]
  path = ~/.gitconfig.local
[alias]
  a  = add --verbose
  af = fz-add
  ap = add-pattern
  au = add --update
  br = branch
  bc = switch --create
  brw = browse
  ci = commit --verbose
  cin = ci --no-verify
  cia = ci --all
  cinc = ci -m '💅'
  cinos = commit --no-gpg-sign
  cinosa = cinos -a
  cinosm = cinos -m
  cinosam = cinos -am
  cim = ci --message
  cinm = ci --message
  ciam = ci --all --message
  co = checkout
  cof = fz-checkout
  conflicts = diff --name-only --diff-filter=U
  cp = cherry-pick
  cpa = cherry-pick --abort
  cpc = cherry-pick --continue
  cry = cherry -v
  current-branch = symbolic-ref HEAD --short
  d  = diff
  default-branch = "!git remote show origin | grep 'HEAD branch' | cut -d ' ' -f 5"
  dc = diff --cached
  dm = "!git show @ --format=short | head -n 2 | tail -n 1 | cut -d ' ' -f 2,3 | xargs git diff"
  dw = diff --word-diff
  f  = fetch --verbose --progress
  fix = ci --fixup
  fixf = fz-fixup
  fixup = ci --fixup HEAD
	foo = "!git switch $(git default-branch) && git fr && git pm; true"
  ft = fetch --verbose --tags
  fr = pull --rebase --verbose
  frm = "!git fr origin $(git default-branch)"
  gh-pages = !git checkout --orphan gh-pages && git rm $(git ls-files) -f
  l  = log --graph --abbrev-commit
  la = log --graph --abbrev-commit --all
  m  = merge --verbose
  nau = update-index --no-assume-unchanged
  p  = push --verbose --progress
  pf = p --force-with-lease
  pfn = pf --no-verify
  pm = prune-merged --delete-worktrees
  pn = p --no-verify
  pod = p origin --delete
  pprq = "!git p && hub prq"
  prq = pull-request
  r  = rebase
  ra = rebase --abort
  rc = rebase --continue
  rh = reset --hard
  re-sign = r --gpg-sign --no-ff
  ri = rebase -i
  rms = "!git rebase $(git default-branch)"
  rom = "!git rebase origin/$(git default-branch)"
  rias = rebase -i --autosquash
  redo = ci --amend --no-edit
  restage = update-index --again
  root = rev-parse --show-toplevel
  rs = restore
  sd = stash drop
  sed  = "!git ls-files | xargs sed -i"
  shaf = fz-sha
  showf = fz-show
  showm = "!git show @ --format=full | tail -n +2 | head -n 1 | cut -d ':' -f 2 | awk 'BEGIN{FS=" ";OFS="..."} {t1=$1;$1=$2;$2=t1;print}'"
  sl = stash list
  sm = submodule
  snapshot = !git stash save "snapshot: $(date)" && git stash apply "stash@{0}"
  sp = stash pop
  ss = stash show -p
  ssf = fz-stash-show
  st  = status --short --branch
  ssv = stash save
  sw = switch
  swc = switch --create
  swd = switch --detach
  swm = switch --merge
  t = tag
  uiau = update-index --assume-unchanged
  undo = reset HEAD~1
  unstage = reset HEAD
  untracked = ls-files --others --exclude-standard
  wc = log --raw
  wip = ci --message '•••••<[WIP]>•••••' --no-verify
  wt = worktree
  wta = worktree add
  wtr = worktree remove
  wtm = worktree move
[color]
  ui = auto
[core]
  excludesfile = ~/.config/git/ignore
[diff]
  algorithm = patience
[format]
  pretty = %C(yellow)%h •%Creset%C(red)%d%Creset %s %Cgreen• %cr by %Creset%C(magenta)%an%Creset %Creset%C(cyan)|%G?|
[github]
  user = fuadsaud
[hub]
  protocol = https
[merge]
  defaultToUpstream = true
[push]
  default = current
  autoSetupRemote = true
[gitsh]
  defaultCommand = status -sb
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[rebase]
  autoStash = true
[pull]
  rebase = true
[advice]
  detachedHead = false
[core]
  pager = delta
[interactive]
  diffFilter = delta --color-only
[init]
  defaultBranch = main
